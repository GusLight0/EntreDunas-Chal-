# Copie este arquivo para ".env" (não versionado) para testar localmente com
# `netlify dev`, ou cadastre estes mesmos nomes em:
# Netlify -> Site configuration -> Environment variables

# Painel do desenvolvedor do Mercado Pago > Credenciais de teste (depois de produção)
MP_ACCESS_TOKEN=

# Firebase Console > Configurações do projeto > Contas de serviço >
# "Gerar nova chave privada" baixa um .json — cole o CONTEÚDO inteiro
# desse arquivo aqui, em uma linha só.
FIREBASE_SERVICE_ACCOUNT=
